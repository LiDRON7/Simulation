# GitHub container registry namespace (your GitHub org or username)
GITHUB_REPOSITORY=lidron7/simulation

# VNC password (used when ENABLE_VNC=true)
VNC_PASSWORD=px4vnc

# ROS 2 domain ID — keep 0 unless running multiple robots
ROS_DOMAIN_ID=0

# ─────────────────────────────────────────────
# Platform behavior toggle

# macOS / headless:
#   ENABLE_VNC=true  → use VNC (connect to localhost:5900)
#
# Linux desktop:
#   ENABLE_VNC=false → use host X11 (Gazebo opens locally)
ENABLE_VNC=false

