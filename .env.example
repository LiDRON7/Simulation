# Copy to .env and fill in values before running
# cp .env.example .env

# GitHub container registry namespace (your GitHub org or username)
GITHUB_REPOSITORY=your-org/drone-sim

# VNC password for dev environment (macOS VNC Viewer)
VNC_PASSWORD=px4vnc

# ROS 2 domain ID — keep 0 unless running multiple robots
ROS_DOMAIN_ID=0
