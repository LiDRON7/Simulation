FROM ros:jazzy

ENV DEBIAN_FRONTEND=noninteractive

# ─── Core simulation stack ────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    ros-jazzy-ros-gz \
    ros-jazzy-vision-opencv \
    ros-jazzy-cv-bridge \
    ros-jazzy-sensor-msgs \
    ros-jazzy-geometry-msgs \
    ros-jazzy-nav-msgs \
    ros-jazzy-tf2-ros \
    ros-jazzy-tf2-geometry-msgs \
    python3-colcon-common-extensions \
    python3-pip \
    x11-apps \
    mesa-utils \
    vim \
    htop \
    screen \
    && rm -rf /var/lib/apt/lists/*

# ─── Software rendering fallback ─────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    libgl1-mesa-dri \
    libglx-mesa0 \
    && rm -rf /var/lib/apt/lists/*

# ─── PX4 build tools ─────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    astyle build-essential ccache cmake cppcheck \
    file g++ gcc gdb git lcov curl wget lsb-release gnupg \
    libssl-dev libxml2-dev libxml2-utils \
    make ninja-build \
    python3 python3-dev python3-pip python3-setuptools python3-wheel \
    rsync shellcheck unzip zip \
    bc libunwind-dev cppzmq-dev \
    && rm -rf /var/lib/apt/lists/*

# ─── Install Gazebo Harmonic system libraries from osrfoundation ─────────────
# PX4's CMakeLists uses plain find_package(gz-transport13) etc. — it does NOT
# understand the ROS vendor shim pattern. So we need real system-level gz dev
# headers that pkg-config can find directly (under /usr, not /opt/ros/jazzy/).
# These coexist fine with the ROS vendor packages; they just add system copies.
RUN wget https://packages.osrfoundation.org/gazebo.gpg \
        -O /usr/share/keyrings/pkgs-osrf-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/pkgs-osrf-archive-keyring.gpg] \
        http://packages.osrfoundation.org/gazebo/ubuntu-stable $(lsb_release -cs) main" \
        > /etc/apt/sources.list.d/gazebo-stable.list && \
    apt-get update && apt-get install -y \
        gz-harmonic \
    && rm -rf /var/lib/apt/lists/*

# ─── Clone PX4 ───────────────────────────────────────────────────────────────
RUN git clone --depth 1 --branch v1.15.0 --recursive \
    https://github.com/PX4/PX4-Autopilot.git /px4

# ─── PX4 Python deps ─────────────────────────────────────────────────────────
RUN pip3 install --break-system-packages -r /px4/Tools/setup/requirements.txt

# ─── Build PX4 SITL — pure compile step, nothing launches ────────────────────
# gz-harmonic is now on the system pkg-config path so CMake finds it directly.
# We only call make px4_sitl_default (no model suffix) — this compiles
# gz_bridge without trying to launch a simulator.
RUN /bin/bash -c " \
    cd /px4 && \
    make px4_sitl_default \
"

# Strip only the main px4 binary — do NOT delete anything else.
# gz_bridge and other Gazebo artifacts live alongside it and must survive.
RUN strip /px4/build/px4_sitl_default/bin/px4

ENV GZ_SIM_RESOURCE_PATH=/drone_sim/models:/drone_sim/worlds:/px4/Tools/simulation/gz/models

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]

WORKDIR /drone_sim
