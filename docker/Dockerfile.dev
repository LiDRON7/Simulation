FROM ros:jazzy

ENV DEBIAN_FRONTEND=noninteractive

# ─── Core simulation stack ────────────────────────────────────────────────────
# ros-jazzy-ros-gz  →  Gazebo Harmonic + ROS 2 bridge (official Jazzy pairing)
# ros-jazzy-vision-opencv, cv-bridge  →  for OAK-D Pro image processing
# ros-jazzy-sensor-msgs-py  →  PointCloud2 / Image / Imu message types
# python3-colcon-common-extensions  →  build tool for your ROS 2 workspace
RUN apt-get update && apt-get install -y \
    ros-jazzy-ros-gz \
    ros-jazzy-vision-opencv \
    ros-jazzy-cv-bridge \
    ros-jazzy-sensor-msgs \
    ros-jazzy-geometry-msgs \
    ros-jazzy-nav-msgs \
    ros-jazzy-tf2-ros \
    ros-jazzy-tf2-geometry-msgs \
    python3-colcon-common-extensions \
    python3-pip \
    x11-apps \
    mesa-utils \
    vim \
    htop \
    && rm -rf /var/lib/apt/lists/*

# ─── Software rendering fallback (for non-GPU hosts e.g. Mac VMs) ────────────
# libgl1-mesa-dri   →  provides the llvmpipe / softpipe drivers
# libglx-mesa0      →  Mesa GLX so the X11 OpenGL path works without a GPU
RUN apt-get update && apt-get install -y \
    libgl1-mesa-dri \
    libglx-mesa0 \
    && rm -rf /var/lib/apt/lists/*

# ─── Shell environment ────────────────────────────────────────────────────────
RUN echo "source /opt/ros/jazzy/setup.bash" >> ~/.bashrc \
    # Tell Gazebo where to find your custom models and worlds
    && echo 'export GZ_SIM_RESOURCE_PATH=/drone_sim/models:${GZ_SIM_RESOURCE_PATH}' >> ~/.bashrc \
    && echo 'export GZ_SIM_RESOURCE_PATH=/drone_sim/worlds:${GZ_SIM_RESOURCE_PATH}' >> ~/.bashrc \
    # Source your ROS 2 workspace if it has been built
    && echo '[ -f /drone_sim/ros2_ws/install/setup.bash ] && source /drone_sim/ros2_ws/install/setup.bash' >> ~/.bashrc \
    && echo "alias sb='source ~/.bashrc'" >> ~/.bashrc

# ─── Entrypoint ───────────────────────────────────────────────────────────────
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]

# Default: launch the outdoor field world
CMD ["gz", "sim", "/drone_sim/worlds/outdoor_field.sdf"]
