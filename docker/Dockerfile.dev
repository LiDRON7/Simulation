FROM ros:jazzy

ENV DEBIAN_FRONTEND=noninteractive

# ─── Core simulation stack ────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    ros-jazzy-ros-gz \
    ros-jazzy-vision-opencv \
    ros-jazzy-cv-bridge \
    ros-jazzy-sensor-msgs \
    ros-jazzy-geometry-msgs \
    ros-jazzy-nav-msgs \
    ros-jazzy-tf2-ros \
    ros-jazzy-tf2-geometry-msgs \
    python3-colcon-common-extensions \
    python3-pip \
    x11-apps \
    mesa-utils \
    vim \
    htop \
    screen \
    && rm -rf /var/lib/apt/lists/*

# ─── Software rendering fallback ─────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    libgl1-mesa-dri \
    libglx-mesa0 \
    && rm -rf /var/lib/apt/lists/*

# ─── PX4 build dependencies ──────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    git cmake ninja-build \
    python3-setuptools python3-wheel python3-jinja2 \
    python3-jsonschema python3-numpy python3-packaging \
    python3-ply python3-serial python3-toml python3-yaml \
    gcc g++ gdb clang make astyle \
    && rm -rf /var/lib/apt/lists/*

# ─── Clone PX4 ───────────────────────────────────────────────────────────────
RUN git clone --depth 1 --branch v1.15.0 --recursive \
    https://github.com/PX4/PX4-Autopilot.git /px4

# ─── PX4 Python deps ─────────────────────────────────────────────────────────
RUN pip3 install --break-system-packages \
    -r /px4/Tools/setup/requirements.txt

# ─── Build PX4 SITL + strip build artifacts to save space ────────────────────
RUN cd /px4 \
    && DONT_RUN=1 make px4_sitl_default \
    && find /px4/build/px4_sitl_default -mindepth 1 -maxdepth 1 \
         ! -name 'bin' ! -name 'etc' \
         -exec rm -rf {} + \
    && strip /px4/build/px4_sitl_default/bin/px4

ENV GZ_SIM_RESOURCE_PATH=/drone_sim/models:/drone_sim/worlds:/px4/Tools/simulation/gz/models

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]

WORKDIR /drone_sim
