FROM ros:jazzy

ENV DEBIAN_FRONTEND=noninteractive

# Install Gazebo Harmonic + ROS-GZ bridge for Jazzy
RUN apt-get update && apt-get install -y \
    ros-jazzy-ros-gz \
    x11-apps \
    mesa-utils \
    && rm -rf /var/lib/apt/lists/*

# Source ROS 2 automatically in every shell
RUN echo "source /opt/ros/jazzy/setup.bash" >> ~/.bashrc

# Default command: launch Gazebo Harmonic GUI
CMD ["/bin/bash", "-c", "source /opt/ros/jazzy/setup.bash && gz sim --gui-config /dev/null"]
