FROM ros:jazzy

ENV DEBIAN_FRONTEND=noninteractive

# ─── Core simulation stack ────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    ros-jazzy-ros-gz \
    ros-jazzy-vision-opencv \
    ros-jazzy-cv-bridge \
    ros-jazzy-sensor-msgs \
    ros-jazzy-geometry-msgs \
    ros-jazzy-nav-msgs \
    ros-jazzy-tf2-ros \
    ros-jazzy-tf2-geometry-msgs \
    python3-colcon-common-extensions \
    python3-pip \
    x11-apps \
    mesa-utils \
    vim \
    htop \
    && rm -rf /var/lib/apt/lists/*

# ─── Software rendering fallback ─────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    libgl1-mesa-dri \
    libglx-mesa0 \
    && rm -rf /var/lib/apt/lists/*

# ─── PX4 build dependencies ──────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    git \
    cmake \
    ninja-build \
    python3-pip \
    python3-setuptools \
    python3-wheel \
    python3-jinja2 \
    python3-jsonschema \
    python3-numpy \
    python3-packaging \
    python3-ply \
    python3-serial \
    python3-toml \
    python3-yaml \
    gcc \
    g++ \
    gdb \
    clang \
    make \
    astyle \
